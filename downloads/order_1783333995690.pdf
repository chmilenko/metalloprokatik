#clock-loader{
    width: 2.5rem;
    height: 2.5rem;
    border: 2px solid #ccc;
    border-radius: 50%;
    position: relative;
    margin: 2rem auto;
    margin-left: 0px;
}


#clock-loader:after, #clock-loader:before{
    position: absolute;
    content:"";
    background-color: #ccc;
}


#clock-loader:after{
    width: 1rem;
    height: 0.2rem;
    top: 1.05rem;
    left: 1.05rem;
    transform-origin: 1px 1px;
    animation: rotateHand 2s linear infinite;
}

#clock-loader:before{
    width: 0.8rem;
    height: 0.2rem;
    top: 1.05rem;
    left: 1.05rem;
    transform-origin: 1px 1px;
    animation: rotateHand 8s linear infinite;
}

@keyframes rotateHand{
    0%{transform:rotate(0deg)}
    100%{transform:rotate(360deg)}
}


