<script>

function send_ok() {

  $('#res_time').hide();
  $('#send_stat').show();
}


function rez_ok() {
  var lst = 'действителен для оплаты до 07.07.2026';
  lst = lst.replace(', зарезервирован','');
  $('#res_time').hide();
  $('#res_btn').hide();
  $('#res_del').show();
  $('#res_stat').show();
  $('#lstat').html( lst  +  ', зарезервирован </br></br>'  );
  $('#lstat_span').html( lst  +  ', зарезервирован'  );

}

function rez_del() {
  var lst = 'действителен для оплаты до 07.07.2026';
  lst = lst.replace(', зарезервирован','');

  $('#res_time').hide();
  $('#res_btn').show();
  $('#res_del').hide();
  $('#res_stat').hide();
  $('#lstat').html( lst + '</br></br>'  );
  $('#lstat_span').html( lst );

}

function set_rez(pStat)
{
  var idbasket = 9435278; 
  $.get("/lib_asp/ajasp.asp",{id:7,idb:idbasket,par:pStat}, function(result ) {
      console.log(result);
     })
   .done(function( data ) {
	console.log("set rez");
  });
}

$('#res_del').on('click', function(e) {
  var target = $(e.target);
  $('#res_del').hide();
  $('#res_time').show();

  set_rez(0);
  setTimeout(rez_del, 1000);


});


$('#res_btn').on('click', function(e) {
  var target = $(e.target);

  $('#res_btn').hide();
  $('#res_time').show();

  set_rez(1);
  setTimeout(rez_ok, 1000);

});



function set_send(pEmail)
{
  var sid = '2LTI37'; 
  
      $.get("/lib_asp/ajasp.asp",{id:8,idb:sid,email:pEmail}, function(result ) {
         console.log(result);
        })
      .done(function( data ) {
	console.log("send sch");
       });
}


$('#send_btn').on('click', function(e) {
  var target = $(e.target);


  $('#ErrEmail').html('');

  var pEmail = $('#email').val();
  if (pEmail !== '') {
	  $('#send_btn').hide();
	  $('#res_time').show();
	  set_send(pEmail);   
          setTimeout(send_ok, 1000);
    }
  else
    {
	$('#ErrEmail').html('Заполните адрес');
    }


});

</script>


